{
  "routes": [
    {
      "route": "/subscribe.html",
      "serve": "/subscribe.html"
    },
    {
      "route": "/subscribe-success.html",
      "serve": "/subscribe-success.html"
    },
    {
      "route": "/index.html",
      "serve": "/index.html"
    },
    {
      "route": "/*",
      "rewrite": "/index.html"
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/subscribe.html", "/subscribe-success.html", "/*.html"]
  }
}
