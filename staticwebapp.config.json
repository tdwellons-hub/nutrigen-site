{
  "routes": [
    {
      "route": "/password.html",
      "serve": "/password.html"
    },
    {
      "route": "/index.html",
      "serve": "/index.html"
    },
    {
      "route": "/*",
      "rewrite": "/index.html"
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/password.html", "/*.html"]
  }
}
